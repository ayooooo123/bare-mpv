{
  "name": "bare-mpv",
  "version": "0.1.0",
  "addon": true,
  "description": "Bare native addon for libmpv video playback",
  "main": "index.js",
  "scripts": {
    "postinstall": "node scripts/postinstall.js",
    "build": "bare-make generate && bare-make build && bare-make install",
    "build:generate": "bare-make generate",
    "build:compile": "bare-make build",
    "build:install": "bare-make install",
    "test": "bare test.js"
  },
  "devDependencies": {
    "bare-make": "^1.7.2",
    "cmake-bare": "^1.7.6",
    "cmake-meson": "^1.1.0",
    "cmake-ports": "^1.5.10",
    "cmake-zig": "^1.0.0"
  },
  "engines": {
    "bare": ">=2.0.0"
  },
  "files": [
    "binding.js",
    "binding.cc",
    "index.js",
    "CMakeLists.txt",
    "cmake",
    "scripts",
    "vendor/mpv",
    "prebuilds"
  ]
}
